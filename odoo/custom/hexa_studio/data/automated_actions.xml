<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_crm_lead_create" model="ir.actions.server">
        <field name="name">HEXA: CRM Lead Created</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">env['hexa.webhook'].dispatch(record, 'create')</field>
    </record>
    <record id="automated_action_crm_create" model="base.automation">
        <field name="name">HEXA: CRM Lead Created</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="trigger">on_create</field>
        <field name="action_server_ids" eval="[(4, ref('action_crm_lead_create'))]"/>
    </record>

    <record id="action_crm_lead_update" model="ir.actions.server">
        <field name="name">HEXA: CRM Lead Updated</field>
