# Normalize all text files to LF in both the repository and working tree.
# This eliminates CRLF/LF churn across Windows/macOS/Linux checkouts.
* text=auto eol=lf

# Windows shell scripts must keep CRLF to execute correctly under cmd.exe
*.bat text eol=crlf
*.cmd text eol=crlf

# Lockfiles are text; keep them LF for clean diffs
package-lock.json text eol=lf
pnpm-lock.yaml text eol=lf
yarn.lock text eol=lf
