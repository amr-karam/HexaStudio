#!/bin/bash
set -euo pipefail

# post-checkout — Worktree-aware lifecycle hook
# Fires after git checkout, git switch, git clone, or git worktree operations.
# Args: <prev-head> <new-head> <1=branch-checkout|0=file-checkout>

# Only run on branch checkouts (not file-level checkouts)
[ "$3" = "0" ] && exit 0

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -z "$ROOT" ] && exit 0

cd "$ROOT"

# ── Skip if HEAD is detached or unborn ──────────────────────────────────────
HEAD=$(git rev-parse --short HEAD 2>/dev/null || echo "unborn")

# Skip automatic setup in linked worktrees.
# In a linked worktree (created by `git worktree add`), $ROOT/.git is a file
# pointing at the real gitdir; in the main checkout/clone it is a directory.
# Worktrees are often short-lived, so skip the heavy install/build here and let
# the developer run `bash .setup.sh` on demand. Clones/main checkouts still set up.
if [ -f "$ROOT/.git" ]; then
  echo "  Linked worktree detected — skipping automatic setup."
  echo "  Run 'bash .setup.sh' inside the worktree if you need dependencies."
  exit 0
fi

# ── Detect new/uninitialized worktree ────────────────────────────────────────
if [ ! -d "node_modules" ]; then
  echo ""
  echo "━━━ Worktree Lifecycle ─────────────────────────────────────────────"
  echo "  Detected uninitialized worktree (no node_modules)."
  echo "  Running worktree setup..."
  echo "────────────────────────────────────────────────────────────────────"
  echo ""

  if [ -f ".setup.sh" ]; then
    bash .setup.sh
  else
    # Match the documented install/build contract (AGENTS.md / ci.yml).
    npm install --legacy-peer-deps --no-audit --no-fund && \
      SKIP_ENV_VALIDATION="${SKIP_ENV_VALIDATION:-true}" \
      NEXT_PUBLIC_API_URL="${NEXT_PUBLIC_API_URL:-https://api.hexastudio.net}" \
      NEXT_PUBLIC_CMS_URL="${NEXT_PUBLIC_CMS_URL:-https://cms.hexastudio.net}" \
      NEXT_PUBLIC_SITE_URL="${NEXT_PUBLIC_SITE_URL:-https://hexastudio.net}" \
      npm run build
  fi

  echo ""
  echo "━━━ Worktree ready ─────────────────────────────────────────────────"
  exit 0
fi

# ── Detect dependency changes vs previous checkout ──────────────────────────
if [ -f "package-lock.json" ]; then
  LOCK_DIFF=$(git diff HEAD@{1} -- package-lock.json 2>/dev/null || true)
  if [ -n "$LOCK_DIFF" ]; then
    echo ""
    echo "━━━ Worktree Lifecycle ─────────────────────────────────────────────"
    echo "  package-lock.json changed since last checkout."
    echo "  Running npm install..."
    echo "────────────────────────────────────────────────────────────────────"
    npm install --legacy-peer-deps --no-audit --no-fund
  fi
fi
