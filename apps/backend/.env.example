# Required
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
CMS_URL=http://localhost:1337

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_HOST=localhost
MINIO_PORT=9000
# MINIO_USE_SSL=false

# Odoo ERP
ODOO_HOST=localhost
ODOO_PORT=8069
ODOO_DB=hexastudio
ODOO_USER=admin
ODOO_PASSWORD=change-me-odoo-password
# ODOO_WEBHOOK_SECRET=

# Webhook Retry Queue (defaults shown)
# WEBHOOK_RETRY_MAX_ATTEMPTS=5
# WEBHOOK_RETRY_BACKOFF_MS=60000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# Vector Store (Qdrant)
# VECTOR_HOST=localhost
# VECTOR_PORT=6333
# VECTOR_API_KEY=

# AI / OpenAI (paid chat + embeddings)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AI / FreeTheAi (free OpenAI-compatible chat gateway)
# To switch: AI_CHAT_PROVIDER=freetheai + set FREETHEAI_API_KEY
# AI_CHAT_PROVIDER=openai
# FREETHEAI_API_KEY=sta_...
# FREETHEAI_BASE_URL=https://api.freetheai.xyz/v1
# FREETHEAI_MODEL=bbl/gemini-3.5-flash
 
# Optional
PORT=4000
# SENTRY_DSN=https://...
# CORS_ORIGINS=http://localhost:3000
NODE_ENV=development
