{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "incremental": false,
    "tsBuildInfoFile": null,
    "paths": {
      "@/*": ["./src/*"],
      "@hexastudio/types": ["../../packages/types/dist/index.d.ts"],
      "@hexastudio/*": ["../../packages/*/dist"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
