# HEXA Hub Worker — Environment Variables
# Copy to .env and adjust for your environment.

REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=5
LOG_LEVEL=info

# SMTP (Email delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@hexastudio.net

# AI (Gemini)
GEMINI_API_KEY=
