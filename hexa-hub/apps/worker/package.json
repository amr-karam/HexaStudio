{
  "name": "@hexa-hub/worker",
  "version": "0.1.0",
  "description": "HEXA Hub Background Worker",
  "main": "src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@hexa-hub/types": "*",
    "@types/nodemailer": "^8.0.1",
    "axios": "^1.18.1",
    "bull": "^4.12.0",
    "dotenv": "^16.3.0",
    "ioredis": "^5.3.0",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@types/bull": "^4.10.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
