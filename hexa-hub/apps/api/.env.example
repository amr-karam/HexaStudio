# HEXA Hub API — Environment Variables
# Copy to .env and adjust for your environment.

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=hub_user
DB_PASSWORD=hub_password
DB_NAME=hub_db

# TypeORM — NEVER set DB_SYNCHRONIZE=true in production
DB_SYNCHRONIZE=false
DB_RUN_MIGRATIONS=true
DB_LOGGING=false

# Auth
JWT_SECRET=change-me-in-production

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://hexastudio.net,https://www.hexastudio.net

# Redis (cache & job queue producer)
REDIS_URL=redis://localhost:6379

# Odoo integration (optional)
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=

# Object storage (optional)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hub-files
