# GitLab CE Environment Variables
# Copy this file to .env.gitlab and fill in values.

# GitLab external URL
GITLAB_URL=http://19.16.1.100:8929

# Container Registry URL
GITLAB_REGISTRY=http://19.16.1.100:5050

# Container Registry HTTP secret (32-byte hex)
# Generate with: openssl rand -hex 32
REGISTRY_HTTP_SECRET=replace-me-with-openssl-rand-hex-32

# SSH port for git+ssh access
GITLAB_SSH_PORT=2222

# ============================================
# CI/CD Variables (set in GitLab UI, not here)
# ============================================
# Map from GitHub secrets → GitLab CI/CD variables:
#
#   GITHUB_TOKEN                  → GITLAB_TOKEN (auto-provided)
#   SSH_PRIVATE_KEY               → SSH_PRIVATE_KEY (masked, file type)
#   PROD_SERVER_IP                → PROD_SERVER_IP (masked)
#   PROD_SERVER_USER              → PROD_SERVER_USER (masked)
#   PROD_SSH_KEY                  → PROD_SSH_KEY (masked, file type)
#   STAGING_SERVER_IP             → STAGING_SERVER_IP
#   STAGING_SERVER_USER           → STAGING_SERVER_USER
#   STAGING_SSH_KEY               → STAGING_SSH_KEY (masked, file type)
#   SNYK_TOKEN                    → SNYK_TOKEN (masked)
#   LHCI_GITHUB_APP_TOKEN         → LHCI_TOKEN (not needed for GitLab — use LHCI_PUSH_TARGET_URL)

# Frontend build-time public env vars (set as group/project variables, NOT masked):
#   NEXT_PUBLIC_API_URL=https://api.hexastudio.net
#   NEXT_PUBLIC_CMS_URL=https://cms.hexastudio.net
#   NEXT_PUBLIC_SITE_URL=https://hexastudio.net
#   NEXT_PUBLIC_STRAPI_API_URL=https://cms.hexastudio.net
