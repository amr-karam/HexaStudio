{
  "name": "hexastudio",
  "version": "1.0.0",
  "private": true,
  "description": "HexaStudio.net — 3D creative studio platform",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=backend",
    "dev:cms": "turbo run dev --filter=cms",
    "dev:frontend": "turbo run dev --filter=frontend",
    "docker:build": "docker compose build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:up": "docker compose up -d",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "npm run test:e2e --workspace=apps/frontend",
    "test:e2e:ui": "playwright test --ui --config e2e/playwright.config.ts",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.18.1",
    "framer-motion": "^11.18.2",
    "libsodium-wrappers": "^0.8.4"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "turbo": "^2.10.4"
  },
  "overrides": {
    "framer-motion": "^11.18.2"
  },
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "apps/cms",
    "packages/types",
    "packages/ui",
    "packages/utils"
  ]
}
