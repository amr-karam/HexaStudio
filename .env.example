# --- Server Configuration ---
SERVER_IP=127.0.0.1

# --- Database ---
POSTGRES_USER=hexa_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hexastudio_db

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password

# --- MinIO ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_me_strong_password

# --- Backend ---
PORT=4000
SENTRY_DSN=
JWT_SECRET=generate_a_random_string_here

# --- CMS (Strapi) ---
ADMIN_JWT_SECRET=generate_a_random_string_here
API_TOKEN_SALT=generate_a_random_string_here
APP_KEYS=key1,key2,key3,key4

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost/api

# --- SSL/TLS (Traefik ACME) ---
# Set to 'true' to enable SSL via Let's Encrypt
TRAEFIK_ACME_ENABLED=false
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@hexastudio.net

# --- Cloudflare (Optional, for DNS challenge) ---
# Required if using Cloudflare DNS challenge for SSL
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=

# --- Domain Configuration ---
FRONTEND_HOST=hexastudio.net
API_HOST=api.hexastudio.net
CMS_HOST=cms.hexastudio.net
STORAGE_HOST=storage.hexastudio.net
STORAGE_CONSOLE_HOST=storage-console.hexastudio.net
GRAFANA_HOST=grafana.hexastudio.net
PROMETHEUS_HOST=prometheus.hexastudio.net
TRAEFIK_HOST=traefik.hexastudio.net
